---
import { Image } from 'astro:assets';
import logo from '../img/logo.svg';
import github from '../img/github-light.svg';
---

<header class="site-header">
    <div class="contain">
        <p class="site-title">
            <a href="/">
                Alexander
            </a>
        </p>
        <div class="get">
            <p class="version">1.0.3</p>
            <a href="https://github.com/samhermes/alexander">
                <Image src={github} alt="" />
                <span class="screen-reader-text">Alexander on GitHub</span>
            </a>
        </div>
    </div>
</header>
<style lang="scss">
    .site-header {
        background: var(--background);
        color: #fff;
        padding: 0.75rem 1.5rem;

        @media screen and (min-width: 50em) {
            padding: 0.75rem 3rem;
        }

        a {
            color: inherit;
            text-decoration: none;

            &:hover,
            &:focus,
            &:active {
                text-decoration: underline;
            }
        }

        .contain {
            display: flex;
            align-items: center;
        }

        .site-title {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 500;

            a {
                text-decoration: none;
                padding: 0.3rem 0.75rem;
                border-radius: 0.5rem;
                margin-left: -0.75rem;
            }
        }

        .get {
            margin-left: auto;
        }
    }

    .get {
        display: flex;

        a {
            will-change: opacity;
            transition: opacity 0.15s cubic-bezier(0.65, 0.05, 0.36, 1);

            &:hover {
                opacity: 0.5;
            }
        }
    }

    .version {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: 0;
        padding-right: 1rem;
        border-right: 2px solid rgba(255, 255, 255, 0.25);
        margin-right: 1rem;
    }
</style>
